select_tools() {
    local -n TOOL_MAP=$1
    local CAT_NAME=$2
    local SELECTED=()

    while true; do
        clear
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "  ${BOLD}${WHITE}$CAT_NAME${NC}"
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""

        local i=1
        local TOOL_NAMES=()

        for tool in "${!TOOL_MAP[@]}"; do
            TOOL_NAMES+=("$tool")
            local status=""
            local color="${NC}"
            if command -v "$tool" &>/dev/null; then
                status=" ${GREEN}[✓ installed]${NC}"
            fi
            printf "  ${YELLOW}%3d)${NC} ${CYAN}%-30s${NC} ${DIM}%s${NC}%b\n" \
                "$i" "$tool" "${TOOL_MAP[$tool]}" "$status"
            ((i++))
        done

        echo ""
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "  ${YELLOW}  a)${NC} Install ALL tools in this category"
        echo -e "  ${YELLOW}  s)${NC} Install only NOT installed tools"
        echo -e "  ${YELLOW}  b)${NC} Back to main menu"
        echo ""
        echo -e "  ${DIM}Enter numbers separated by spaces: e.g.  1 3 7 12${NC}"
        echo ""
        read -p "  Choice: " INPUT

        case "$INPUT" in
            b|B|q|Q) return ;;
            a|A) SELECTED=("${TOOL_NAMES[@]}") ;;
            s|S)
                for tool in "${TOOL_NAMES[@]}"; do
                    command -v "$tool" &>/dev/null || SELECTED+=("$tool")
                done
                ;;
            *)
                for num in $INPUT; do
                    if [[ "$num" =~ ^[0-9]+$ ]]; then
                        idx=$((num-1))
                        [ -n "${TOOL_NAMES[$idx]}" ] && SELECTED+=("${TOOL_NAMES[$idx]}")
                    fi
                done
                ;;
        esac

        if [ ${#SELECTED[@]} -eq 0 ]; then
            echo -e "\n  ${RED}No tools selected!${NC}"
            sleep 1
            continue
        fi

        # Confirm
        echo ""
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "  ${WHITE}Selected tools (${#SELECTED[@]}):${NC}"
        for t in "${SELECTED[@]}"; do
            echo -e "  ${DIM}→${NC} $t"
        done
        echo ""
        read -p "  Proceed with installation? [Y/n]: " CONFIRM
        [[ "$CONFIRM" =~ ^[Nn]$ ]] && SELECTED=() && continue

        # Install
        echo ""
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "  ${CYAN}Updating apt cache...${NC}"
        sudo apt update -qq 2>/dev/null
        echo ""

        SUCCESS=0; FAILED=0; SKIP=0

        for tool in "${SELECTED[@]}"; do
            if command -v "$tool" &>/dev/null; then
                printf "  ${DIM}%-35s${NC} ${YELLOW}[already installed]${NC}\n" "$tool"
                ((SKIP++))
                continue
            fi
            printf "  ${CYAN}Installing %-28s${NC} " "$tool..."
            if sudo apt install -y "$tool" &>/dev/null 2>&1; then
                echo -e "${GREEN}[✓ done]${NC}"
                ((SUCCESS++))
            else
                # Try pip for Python tools
                if pip3 install "$tool" &>/dev/null 2>&1; then
                    echo -e "${GREEN}[✓ pip]${NC}"
                    ((SUCCESS++))
                else
                    echo -e "${RED}[✗ failed]${NC}"
                    ((FAILED++))
                fi
            fi
        done

        echo ""
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "  ${GREEN}✓ Installed : $SUCCESS${NC}"
        echo -e "  ${YELLOW}⊘ Skipped   : $SKIP (already present)${NC}"
        [ $FAILED -gt 0 ] && echo -e "  ${RED}✗ Failed    : $FAILED${NC}"
        echo ""
        read -p "  Press Enter to continue..."
        SELECTED=()
    done
}

install_all_tools() {
    echo ""
    echo -e "${RED}${BOLD}  ⚠  WARNING: This will attempt to install ALL 300+ tools!${NC}"
    echo -e "${DIM}  This may take 30-60+ minutes and require several GB of disk space.${NC}"
    echo ""
    read -p "  Are you sure? Type YES to confirm: " CONFIRM
    [[ "$CONFIRM" != "YES" ]] && echo -e "\n  ${YELLOW}Aborted.${NC}" && sleep 1 && return

    echo -e "\n  ${CYAN}Updating apt cache...${NC}"
    sudo apt update -qq 2>/dev/null

    local ALL_SUCCESS=0 ALL_FAILED=0

    local ALL_MAPS=(
        INFO_TOOLS WEB_TOOLS PASS_TOOLS WIRELESS_TOOLS
        EXPLOIT_TOOLS REVERSE_TOOLS FORENSICS_TOOLS SNIFF_TOOLS
        VULN_TOOLS SOCIAL_TOOLS STRESSER_TOOLS PRIVESC_TOOLS
        CONTAINER_TOOLS CRYPTO_TOOLS
    )

    for MAP_NAME in "${ALL_MAPS[@]}"; do
        local -n TMAP=$MAP_NAME
        echo ""
        echo -e "  ${YELLOW}─── $MAP_NAME ───${NC}"
        for tool in "${!TMAP[@]}"; do
            if command -v "$tool" &>/dev/null; then
                printf "  ${DIM}%-35s [already installed]${NC}\n" "$tool"
                continue
            fi
            printf "  ${CYAN}%-35s${NC} " "$tool"
            if sudo apt install -y "$tool" &>/dev/null 2>&1; then
                echo -e "${GREEN}[✓]${NC}"
                ((ALL_SUCCESS++))
            else
                echo -e "${RED}[✗]${NC}"
                ((ALL_FAILED++))
            fi
        done
    done

    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "  ${GREEN}Total Installed : $ALL_SUCCESS${NC}"
    echo -e "  ${RED}Total Failed    : $ALL_FAILED${NC}"
    echo ""
    read -p "  Press Enter..."
}

search_tool() {
    echo ""
    read -p "  Search tool name: " QUERY
    QUERY=$(echo "$QUERY" | tr '[:upper:]' '[:lower:]')

    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "  ${WHITE}Results for: \"$QUERY\"${NC}"
    echo ""

    local found=0
    local ALL_MAPS=(
        INFO_TOOLS WEB_TOOLS PASS_TOOLS WIRELESS_TOOLS
        EXPLOIT_TOOLS REVERSE_TOOLS FORENSICS_TOOLS SNIFF_TOOLS
        VULN_TOOLS SOCIAL_TOOLS STRESSER_TOOLS PRIVESC_TOOLS
        CONTAINER_TOOLS CRYPTO_TOOLS
    )

    for MAP_NAME in "${ALL_MAPS[@]}"; do
        local -n TMAP=$MAP_NAME
        for tool in "${!TMAP[@]}"; do
            local tool_lower=$(echo "$tool" | tr '[:upper:]' '[:lower:]')
            local desc_lower=$(echo "${TMAP[$tool]}" | tr '[:upper:]' '[:lower:]')
            if [[ "$tool_lower" == *"$QUERY"* || "$desc_lower" == *"$QUERY"* ]]; then
                local status="${RED}[not installed]${NC}"
                command -v "$tool" &>/dev/null && status="${GREEN}[installed]${NC}"
                printf "  ${CYAN}%-30s${NC} ${DIM}%-40s${NC} %b\n" \
                    "$tool" "${TMAP[$tool]}" "$status"
                ((found++))
            fi
        done
    done

    [ $found -eq 0 ] && echo -e "  ${RED}No results found.${NC}"
    echo ""
    read -p "  Press Enter..."
}

system_info() {
    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "  ${WHITE}System Information${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "  ${YELLOW}OS:${NC}      $(uname -o) $(uname -m)"
    echo -e "  ${YELLOW}Kernel:${NC}  $(uname -r)"
    echo -e "  ${YELLOW}Host:${NC}    $(hostname)"
    echo -e "  ${YELLOW}Disk:${NC}    $(df -h / | awk 'NR==2{print $4" free of "$2}')"
    echo -e "  ${YELLOW}RAM:${NC}     $(free -h | awk '/^Mem/{print $7" free of "$2}')"
    echo ""
    echo -e "  ${YELLOW}Total tools in installer: ${GREEN}300+${NC}"

    local total_installed=0
    local ALL_MAPS=(
        INFO_TOOLS WEB_TOOLS PASS_TOOLS WIRELESS_TOOLS
        EXPLOIT_TOOLS REVERSE_TOOLS FORENSICS_TOOLS SNIFF_TOOLS
        VULN_TOOLS SOCIAL_TOOLS STRESSER_TOOLS PRIVESC_TOOLS
        CONTAINER_TOOLS CRYPTO_TOOLS
    )
    for MAP_NAME in "${ALL_MAPS[@]}"; do
        local -n TMAP=$MAP_NAME
        for tool in "${!TMAP[@]}"; do
            command -v "$tool" &>/dev/null && ((total_installed++))
        done
    done

    echo -e "  ${YELLOW}Tools currently installed: ${GREEN}$total_installed${NC}"
    echo ""
    read -p "  Press Enter..."
}

