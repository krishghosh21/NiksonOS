RED='\033[0;31m'
LRED='\033[1;31m'
GREEN='\033[0;32m'
LGREEN='\033[1;32m'
CYAN='\033[0;36m'
LCYAN='\033[1;36m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

banner() {
    clear
    echo -e "${LGREEN}${BOLD}"
    cat << 'BANNER'
   ██████╗██████╗  █████╗  ██████╗██╗  ██╗
  ██╔════╝██╔══██╗██╔══██╗██╔════╝██║ ██╔╝
  ██║     ██████╔╝███████║██║     █████╔╝
  ██║     ██╔══██╗██╔══██║██║     ██╔═██╗
  ╚██████╗██║  ██║██║  ██║╚██████╗██║  ██╗
