class NiksonCenter(Gtk.Window):

    def __init__(self):
        super().__init__(title="Nikson Center — v2.0 ULTIMATE")
        self.set_default_size(1100, 680)
        self.set_resizable(True)

        self._apply_css()

        self.current_cat = list(TOOLS.keys())[0]
        self.search_query = ""
        self.install_status = {}   # tool -> "installing"|"done"|"failed"
        self.total_tools = sum(len(v) for v in TOOLS.values())

        self._build_ui()
        self.load_category(self.current_cat)
        self.show_all()
        self._refresh_stats()

    # ── CSS ──────────────────────────────────
    def _apply_css(self):
        provider = Gtk.CssProvider()
        provider.load_from_data(CSS.encode('utf-8'))
        Gtk.StyleContext.add_provider_for_screen(
            self.get_screen(), provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

    # ── Build UI ─────────────────────────────
    def _build_ui(self):
        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.add(root)

        root.pack_start(self._build_header(), False, False, 0)

        body = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        root.pack_start(body, True, True, 0)

        body.pack_start(self._build_sidebar(), False, False, 0)
        body.pack_start(self._build_main(), True, True, 0)

        root.pack_end(self._build_statsbar(), False, False, 0)

    # ── Header ───────────────────────────────
    def _build_header(self):
        hdr = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        hdr.get_style_context().add_class("hdr")

        left = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        title = Gtk.Label(label="NIKSON CENTER")
        title.get_style_context().add_class("hdr-title")
        title.set_xalign(0)
        sub = Gtk.Label(label="SECURITY TOOL MANAGER  ·  v2.0 ULTIMATE  ·  375+ TOOLS")
        sub.get_style_context().add_class("hdr-sub")
        sub.set_xalign(0)
        left.pack_start(title, False, False, 0)
        left.pack_start(sub, False, False, 0)
