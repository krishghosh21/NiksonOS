    # ── Stats bar ────────────────────────────
    def _build_statsbar(self):
        bar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        bar.get_style_context().add_class("statsbar")

        self.stat_labels = {}
        for key in ["installed", "total", "categories", "disk"]:
            lbl = Gtk.Label()
            lbl.get_style_context().add_class("stat-item")
            bar.pack_start(lbl, False, False, 0)
            self.stat_labels[key] = lbl

        return bar

    # ── Load category ────────────────────────
    def load_category(self, cat, query=""):
        self.current_cat = cat

        # Sidebar highlight
        for c, btn in self.cat_buttons.items():
            ctx = btn.get_style_context()
            if c == cat:
                ctx.add_class("active")
            else:
                ctx.remove_class("active")

        # Clear
        for child in self.tool_box.get_children():
            self.tool_box.remove(child)

        tools = TOOLS.get(cat, [])
        if query:
            q = query.lower()
            tools = [(t, d) for t, d in tools
                     if q in t.lower() or q in d.lower()]

        title = f"{CAT_ICONS.get(cat,'')}  {cat}  —  {len(tools)} tools"
        self.cat_title_lbl.set_text(title)

        for tool, desc in tools:
            self.tool_box.pack_start(
                self._make_tool_row(tool, desc), False, False, 0)

        self.tool_box.show_all()

    # ── Tool row ─────────────────────────────
    def _make_tool_row(self, tool, desc):
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        row.get_style_context().add_class("tool-card")

        info = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
        nm = Gtk.Label(label=tool)
        nm.get_style_context().add_class("tool-name")
        nm.set_xalign(0)
        ds = Gtk.Label(label=desc)
        ds.get_style_context().add_class("tool-desc")
        ds.set_xalign(0)
        info.pack_start(nm, False, False, 0)
        info.pack_start(ds, False, False, 0)
        row.pack_start(info, True, True, 0)

        # Status widget
        status_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        row.pack_end(status_box, False, False, 0)
        self._set_tool_status_widget(status_box, tool)

        return row

    def _set_tool_status_widget(self, box, tool):
        # Clear box
        for c in box.get_children():
            box.remove(c)

        st = self.install_status.get(tool)

        if st == "installing":
            lbl = Gtk.Label(label="⏳ Installing...")
            lbl.get_style_context().add_class("lbl-installing")
            box.pack_start(lbl, False, False, 0)

        elif st == "done" or self._is_installed(tool):
            lbl = Gtk.Label(label="✓  Installed")
            lbl.get_style_context().add_class("lbl-installed")
            box.pack_start(lbl, False, False, 0)

        elif st == "failed":
            lbl = Gtk.Label(label="✗  Failed")
            lbl.get_style_context().add_class("lbl-failed")
            box.pack_start(lbl, False, False, 0)
            btn = Gtk.Button(label="Retry")
            btn.get_style_context().add_class("btn-install")
            btn.connect("clicked", lambda b: self._do_install(tool, box))
            box.pack_start(btn, False, False, 4)

        else:
            btn = Gtk.Button(label="Install")
            btn.get_style_context().add_class("btn-install")
            btn.connect("clicked", lambda b: self._do_install(tool, box))
            box.pack_start(btn, False, False, 0)

        box.show_all()

    # ── Install single ───────────────────────
    def _do_install(self, tool, status_box):
        self.install_status[tool] = "installing"
        self._set_tool_status_widget(status_box, tool)
        self._log(f"Installing {tool}...")

        def run():
            ret = subprocess.run(
                ["sudo", "apt", "install", "-y", tool],
                capture_output=True, text=True
            ).returncode
            if ret != 0:
                ret = subprocess.run(
                    ["pip3", "install", tool],
                    capture_output=True, text=True
                ).returncode
            GLib.idle_add(self._install_done, tool, status_box, ret)

        threading.Thread(target=run, daemon=True).start()

    def _install_done(self, tool, status_box, code):
        self.install_status[tool] = "done" if code == 0 else "failed"
        if code == 0:
            self._log(f"✓  {tool} installed successfully")
        else:
            self._log(f"✗  {tool} installation failed")
        self._set_tool_status_widget(status_box, tool)
        self._refresh_stats()

    # ── Install all / missing in category ────
    def _install_all_in_cat(self, *_):
        tools = [t for t, _ in TOOLS[self.current_cat]]
        self._batch_install(tools)

    def _install_missing_in_cat(self, *_):
        tools = [t for t, _ in TOOLS[self.current_cat]
                 if not self._is_installed(t)
                 and self.install_status.get(t) != "done"]
        if not tools:
            self._log("All tools in this category are already installed!")
            return
        self._batch_install(tools)

    def _batch_install(self, tools):
        if not tools:
            self._log("Nothing to install.")
            return

        self._log(f"Batch installing {len(tools)} tools...")
        self.progress.set_fraction(0)
        self.progress.show()

        def run():
            subprocess.run(["sudo", "apt", "update", "-qq"],
                           capture_output=True)
            done = 0
            for tool in tools:
                GLib.idle_add(self._log, f"  → {tool}...")
                ret = subprocess.run(
                    ["sudo", "apt", "install", "-y", tool],
                    capture_output=True, text=True
                ).returncode
                if ret != 0:
                    ret = subprocess.run(
                        ["pip3", "install", tool],
                        capture_output=True, text=True
                    ).returncode
                self.install_status[tool] = "done" if ret == 0 else "failed"
                done += 1
                frac = done / len(tools)
                GLib.idle_add(self.progress.set_fraction, frac)
                GLib.idle_add(self._log,
                    f"  {'✓' if ret==0 else '✗'} {tool}")

            GLib.idle_add(self._batch_done, len(tools))

        threading.Thread(target=run, daemon=True).start()

    def _batch_done(self, total):
        self._log(f"Batch install complete — {total} tools processed")
        self.progress.hide()
        self.load_category(self.current_cat, self.search_query)
        self._refresh_stats()

    # ── Search ───────────────────────────────
    def _on_search_changed(self, entry):
        q = entry.get_text().strip()
        self.search_query = q
        if q:
            self._search_all(q)
        else:
            self.load_category(self.current_cat)

    def _search_all(self, q):
        ql = q.lower()
        for c in self.tool_box.get_children():
            self.tool_box.remove(c)

        found = 0
        for cat, tools in TOOLS.items():
            for tool, desc in tools:
                if ql in tool.lower() or ql in desc.lower():
                    self.tool_box.pack_start(
                        self._make_tool_row(tool, desc), False, False, 0)
                    found += 1

        self.cat_title_lbl.set_text(
            f"🔍  Search: \"{q}\"  —  {found} results")
        self.tool_box.show_all()

    # ── Category clicked ─────────────────────
    def _on_cat_clicked(self, btn, cat):
        self.search_entry.set_text("")
        self.search_query = ""
        self.load_category(cat)

    # ── Stats refresh ────────────────────────
    def _refresh_stats(self):
        inst = sum(1 for cat in TOOLS.values()
                   for t, _ in cat if self._is_installed(t))

        self.hdr_installed_lbl.set_text(
            f"{inst} / {self.total_tools} installed")

        self.stat_labels["installed"].set_markup(
            f'<span foreground="#4a6070">Installed: </span>'
            f'<span foreground="#00ff41"><b>{inst}</b></span>  ')
        self.stat_labels["total"].set_markup(
            f'<span foreground="#4a6070">Total: </span>'
            f'<span foreground="#00d4ff"><b>{self.total_tools}</b></span>  ')
        self.stat_labels["categories"].set_markup(
            f'<span foreground="#4a6070">Categories: </span>'
            f'<span foreground="#00d4ff"><b>{len(TOOLS)}</b></span>  ')
        try:
            disk = subprocess.run(
                ["df", "-h", "/"], capture_output=True, text=True
            ).stdout.split("\n")[1].split()[3]
            self.stat_labels["disk"].set_markup(
                f'<span foreground="#4a6070">Free disk: </span>'
                f'<span foreground="#ffd700"><b>{disk}</b></span>')
        except Exception:
            pass

    # ── Helpers ──────────────────────────────
    def _is_installed(self, tool):
        return shutil.which(tool) is not None

    def _log(self, msg):
        end = self.term_buf.get_end_iter()
        self.term_buf.insert(end, f"[nikson] {msg}\n")
        # Auto scroll
        mark = self.term_buf.create_mark(None,
            self.term_buf.get_end_iter(), False)
        self.terminal.scroll_to_mark(mark, 0, True, 0, 1)

    def _get_sysinfo(self):
        try:
            with open('/etc/os-release') as f:
                for line in f:
                    if line.startswith('PRETTY_NAME'):
                        return line.split('=')[1].strip().strip('"')
        except Exception:
            pass
        return "Linux"

