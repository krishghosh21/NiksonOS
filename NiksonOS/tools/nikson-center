    # ── Sidebar ──────────────────────────────
    def _build_sidebar(self):
        sb = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        sb.get_style_context().add_class("sidebar")
        sb.set_size_request(210, -1)

        # Search
        self.search_entry = Gtk.Entry()
        self.search_entry.set_placeholder_text("🔍  Search tools...")
        self.search_entry.get_style_context().add_class("sidebar-search")
        self.search_entry.connect("changed", self._on_search_changed)
        sb.pack_start(self.search_entry, False, False, 0)

        sep = Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL)
        sb.pack_start(sep, False, False, 4)

        # Category scroll
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)

        cat_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
        self.cat_buttons = {}

        for cat, tools in TOOLS.items():
            icon = CAT_ICONS.get(cat, "•")
            lbl = f"{icon}  {cat}  ({len(tools)})"
            btn = Gtk.Button(label=lbl)
            btn.get_style_context().add_class("cat-btn")
            btn.set_relief(Gtk.ReliefStyle.NONE)
            btn.connect("clicked", self._on_cat_clicked, cat)
            cat_box.pack_start(btn, False, False, 0)
            self.cat_buttons[cat] = btn

        scroll.add(cat_box)
        sb.pack_start(scroll, True, True, 0)

        return sb

    # ── Main area ────────────────────────────
    def _build_main(self):
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)

        # Toolbar
        toolbar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
        toolbar.set_margin_start(8)
        toolbar.set_margin_end(8)
        toolbar.set_margin_top(6)
        toolbar.set_margin_bottom(2)

        self.cat_title_lbl = Gtk.Label()
        self.cat_title_lbl.get_style_context().add_class("tool-name")
        self.cat_title_lbl.set_xalign(0)
        toolbar.pack_start(self.cat_title_lbl, True, True, 0)

        btn_all = Gtk.Button(label="⬇  Install All")
        btn_all.get_style_context().add_class("btn-install-all")
        btn_all.connect("clicked", self._install_all_in_cat)
        toolbar.pack_end(btn_all, False, False, 0)

        btn_missing = Gtk.Button(label="⬇  Missing Only")
        btn_missing.get_style_context().add_class("btn-uninstalled-only")
        btn_missing.connect("clicked", self._install_missing_in_cat)
        toolbar.pack_end(btn_missing, False, False, 0)

        # Progress bar (hidden by default)
        self.progress = Gtk.ProgressBar()
        self.progress.set_margin_start(10)
        self.progress.set_margin_end(10)
        self.progress.set_margin_bottom(2)
        self.progress.set_no_show_all(True)

        vbox.pack_start(toolbar, False, False, 0)
        vbox.pack_start(self.progress, False, False, 0)

        # Tool list scroll
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        self.tool_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        self.tool_box.set_margin_top(4)
        self.tool_box.set_margin_bottom(8)
