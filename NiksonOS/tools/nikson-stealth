section() {
    cols=$(tput cols)
    line=$(printf '%*s' "$cols" | tr ' ' '─')
    echo -e "\n${MAGENTA}${line}${NC}"
    echo -e "  ${LMAGENTA}${BOLD}● $1${NC}"
