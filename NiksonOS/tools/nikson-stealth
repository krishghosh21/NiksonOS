}

ok()   { echo -e "  ${LGREEN}[✓]${NC} $1"; }
fail() { echo -e "  ${LRED}[✗]${NC} $1"; }
info() { echo -e "  ${LCYAN}[*]${NC} $1"; }
warn() { echo -e "  ${YELLOW}[!]${NC} $1"; }

check_root() {
    if [ "$EUID" -ne 0 ]; then
        warn "Root required! Run: sudo nikson-stealth"
        exit 1
    fi
}

# ── GET NETWORK INTERFACE ───────────────────────────────────
get_iface() {
    ip route show default | awk '{print $5; exit}'
}

# ── REAL IP ─────────────────────────────────────────────────
get_real_ip() {
    curl -s --max-time 5 "https://api.ipify.org" 2>/dev/null || \
    curl -s --max-time 5 "http://ip-api.com/line/?fields=query" 2>/dev/null
}

# ── TOR SETUP ───────────────────────────────────────────────
setup_tor() {
    section "TOR NETWORK SETUP"

    if ! command -v tor &>/dev/null; then
        info "Installing Tor..."
        apt install -y tor &>/dev/null
    fi
   warn "NOTE: Tor may not work in VMware NAT network"
   warn "On real hardware it will work perfectly"
    # Tor config
    info "Configuring Tor transparent proxy..."
    cat > /etc/tor/torrc << 'EOF'
VirtualAddrNetworkIPv4 10.192.0.0/10
AutomapHostsOnResolve 1
TransPort 9040
DNSPort 5353
SocksPort 9050
EOF

    # Start Tor
    info "Starting Tor service..."
    systemctl restart tor
    sleep 3

    if systemctl is-active tor &>/dev/null; then
        ok "Tor is running!"
    else
        fail "Tor failed to start"
        return 1
       fi

    # iptables rules — route all traffic through Tor
    info "Setting up iptables rules..."

    local IFACE=$(get_iface)
    local TOR_UID=$(id -u debian-tor 2>/dev/null || echo "107")

    # Flush existing
    iptables -F
    iptables -t nat -F
    iptables -t mangle -F

    # Don't nat Tor's own traffic
    iptables -t nat -A OUTPUT \
        -m owner --uid-owner "$TOR_UID" -j RETURN

    # Don't nat local
    iptables -t nat -A OUTPUT \
        -d 127.0.0.1/8 -j RETURN
    iptables -t nat -A OUTPUT \
        -d 192.168.0.0/16 -j RETURN
    iptables -t nat -A OUTPUT \
        -d 10.0.0.0/8 -j RETURN

    # Redirect DNS to Tor
    iptables -t nat -A OUTPUT \
        -p udp --dport 53 -j REDIRECT --to-ports 5353

    # Redirect TCP to Tor transparent proxy
    iptables -t nat -A OUTPUT \
        -p tcp --syn -j REDIRECT --to-ports 9040

    ok "iptables rules applied!"
    ok "All traffic routing through Tor!"
}

# ── MAC CHANGER ─────────────────────────────────────────────
change_mac() {
    section "MAC ADDRESS SPOOFING"

    local IFACE=$(get_iface)
    if [ -z "$IFACE" ]; then
        fail "No network interface found!"
        return 1
    fi

    local OLD_MAC=$(cat /sys/class/net/$IFACE/address 2>/dev/null)
    info "Interface : $IFACE"
    info "Old MAC   : $OLD_MAC"

    # Bring interface down
    ip link set "$IFACE" down

    if command -v macchanger &>/dev/null; then
        macchanger -r "$IFACE" &>/dev/null
        local NEW_MAC=$(macchanger -s "$IFACE" | grep "Current" | \
            awk '{print $3}')
    else
        # Manual random MAC
        local NEW_MAC=$(printf '02:%02x:%02x:%02x:%02x:%02x' \
            $((RANDOM%256)) $((RANDOM%256)) \
            $((RANDOM%256)) $((RANDOM%256)) \
            $((RANDOM%256)))
        ip link set dev "$IFACE" address "$NEW_MAC"
    fi

    # Bring interface up
    ip link set "$IFACE" up
    sleep 1

    local CURRENT_MAC=$(cat /sys/class/net/$IFACE/address 2>/dev/null)
    ok "MAC changed: $OLD_MAC → ${CURRENT_MAC}"
}

# ── AUTO MAC ROTATOR ────────────────────────────────────────
start_mac_rotator() {
    section "AUTO MAC ROTATION"
    read -p "  Rotate MAC every how many minutes? [10]: " INTERVAL
    INTERVAL=${INTERVAL:-10}

    info "Starting MAC rotation every ${INTERVAL} min in background..."

    cat > /tmp/nikson-mac-rotator.sh << EOF
#!/bin/bash
while true; do
    sleep ${INTERVAL}m
    IFACE=\$(ip route | awk '/default/{print \$5; exit}')
    ip link set "\$IFACE" down
    macchanger -r "\$IFACE" &>/dev/null
    ip link set "\$IFACE" up
    logger "nikson-stealth: MAC rotated on \$IFACE"
done
EOF
    chmod +x /tmp/nikson-mac-rotator.sh
    nohup bash /tmp/nikson-mac-rotator.sh &>/dev/null &
    echo $! > /tmp/nikson-mac-rotator.pid

    ok "MAC rotator started (PID: $(cat /tmp/nikson-mac-rotator.pid))"
}

# ── LOG CLEANER ─────────────────────────────────────────────
clean_logs() {
    section "LOG CLEANING"

    info "Clearing system logs..."

    # Journal logs
    journalctl --vacuum-time=1s &>/dev/null
    ok "Journal logs cleared"

    # Auth logs
    for log in /var/log/auth.log /var/log/syslog \
               /var/log/messages /var/log/kern.log \
               /var/log/daemon.log /var/log/user.log; do
        if [ -f "$log" ]; then
            > "$log"
            ok "Cleared: $log"
        fi
    done

    # Bash history
    > ~/.bash_history
    history -c
    ok "Bash history cleared"

    # Root bash history
    > /root/.bash_history
    ok "Root history cleared"

    # Tmp files
    rm -rf /tmp/* /var/tmp/* 2>/dev/null
    ok "Temp files cleared"

    # Thumbnail cache
    rm -rf ~/.cache/thumbnails/* 2>/dev/null
    ok "Thumbnail cache cleared"

    # Recent files
    > ~/.local/share/recently-used.xbel 2>/dev/null
    ok "Recent files list cleared"

    # Wtmp/btmp/lastlog
    > /var/log/wtmp 2>/dev/null
    > /var/log/btmp 2>/dev/null
    > /var/log/lastlog 2>/dev/null
    ok "Login records cleared"

    ok "All logs cleaned!"
}

# ── TOR IP ROTATOR ──────────────────────────────────────────
rotate_tor_ip() {
    section "TOR IP ROTATION"

    if ! systemctl is-active tor &>/dev/null; then
        fail "Tor not running! Start stealth mode first."
        return 1
    fi

    info "Requesting new Tor circuit..."
    (echo authenticate '""'; echo signal newnym; echo quit) | \
        nc 127.0.0.1 9051 &>/dev/null

    sleep 3
    local NEW_IP=$(curl -s --socks5 127.0.0.1:9050 \
        "https://api.ipify.org" 2>/dev/null)
    ok "New Tor IP: ${NEW_IP:-requesting...}"
}

# ── AUTO IP ROTATOR ─────────────────────────────────────────
start_ip_rotator() {
    section "AUTO IP ROTATION"
    read -p "  Rotate Tor IP every how many minutes? [5]: " INTERVAL
    INTERVAL=${INTERVAL:-5}

    # Enable Tor control port
    echo "ControlPort 9051" >> /etc/tor/torrc
    echo "CookieAuthentication 0" >> /etc/tor/torrc
    systemctl restart tor &>/dev/null
    sleep 2

    info "Starting IP rotation every ${INTERVAL} min..."

    cat > /tmp/nikson-ip-rotator.sh << EOF
#!/bin/bash
while true; do
    sleep ${INTERVAL}m
    (echo authenticate '""'; echo signal newnym; echo quit) | \
        nc 127.0.0.1 9051 &>/dev/null
    logger "nikson-stealth: Tor IP rotated"
done
EOF
    chmod +x /tmp/nikson-ip-rotator.sh
    nohup bash /tmp/nikson-ip-rotator.sh &>/dev/null &
    echo $! > /tmp/nikson-ip-rotator.pid

    ok "IP rotator started (PID: $(cat /tmp/nikson-ip-rotator.pid))"
}

# ── HOSTNAME SPOOF ──────────────────────────────────────────
spoof_hostname() {
    section "HOSTNAME SPOOFING"

    local OLD_HOST=$(hostname)
    local RANDOM_HOST="host-$(cat /dev/urandom | tr -dc 'a-z0-9' | \
        fold -w 8 | head -n 1)"

    hostnamectl set-hostname "$RANDOM_HOST"
    ok "Hostname changed: $OLD_HOST → $RANDOM_HOST"
}

# ── DNS CHANGE ──────────────────────────────────────────────
setup_dns() {
    section "SECURE DNS SETUP"

    info "Backing up resolv.conf..."
    cp /etc/resolv.conf /etc/resolv.conf.backup

    # Use Tor DNS + Cloudflare as fallback
    cat > /etc/resolv.conf << 'EOF'
# Nikson Stealth Mode DNS
nameserver 127.0.0.1
nameserver 1.1.1.1
nameserver 9.9.9.9
EOF
    chattr +i /etc/resolv.conf 2>/dev/null

    ok "DNS set to Tor local + Cloudflare + Quad9"
}

# ── STATUS CHECK ────────────────────────────────────────────
check_status() {
    section "ANONYMITY STATUS"

    cols=$(tput cols)
    echo ""

    # Real IP check
    info "Checking current IP..."
    local CURRENT_IP=$(curl -s --max-time 5 \
        "https://api.ipify.org" 2>/dev/null)
    local TOR_IP=$(curl -s --max-time 5 --socks5 127.0.0.1:9050 \
        "https://api.ipify.org" 2>/dev/null)

    echo -e "  ${YELLOW}Direct IP  :${NC} ${CURRENT_IP:-Unable to fetch}"
    echo -e "  ${YELLOW}Tor IP     :${NC} ${TOR_IP:-Tor not active}"

    # Tor status
    echo ""
    if systemctl is-active tor &>/dev/null; then
        ok "Tor       : RUNNING"
    else
        fail "Tor       : NOT RUNNING"
    fi

    # MAC
    local IFACE=$(get_iface)
    local MAC=$(cat /sys/class/net/$IFACE/address 2>/dev/null)
    ok "MAC       : $MAC ($IFACE)"

    # Rotators
    if [ -f /tmp/nikson-ip-rotator.pid ] && \
        kill -0 $(cat /tmp/nikson-ip-rotator.pid) 2>/dev/null; then
        ok "IP Rotator: ACTIVE"
    else
        warn "IP Rotator: NOT ACTIVE"
    fi

    if [ -f /tmp/nikson-mac-rotator.pid ] && \
        kill -0 $(cat /tmp/nikson-mac-rotator.pid) 2>/dev/null; then
        ok "MAC Rotate: ACTIVE"
    else
        warn "MAC Rotate: NOT ACTIVE"
    fi

    # Hostname
    ok "Hostname  : $(hostname)"

    echo ""
}

# ── STOP STEALTH ────────────────────────────────────────────
stop_stealth() {
    section "STOPPING STEALTH MODE"

    # Kill rotators
    [ -f /tmp/nikson-ip-rotator.pid ] && \
        kill $(cat /tmp/nikson-ip-rotator.pid) 2>/dev/null && \
        ok "IP rotator stopped"

    [ -f /tmp/nikson-mac-rotator.pid ] && \
        kill $(cat /tmp/nikson-mac-rotator.pid) 2>/dev/null && \
        ok "MAC rotator stopped"

    # Flush iptables
    iptables -F
    iptables -t nat -F
    ok "iptables rules cleared"
    iptables -P INPUT ACCEPT
    iptables -P OUTPUT ACCEPT
    iptables -P FORWARD ACCEPT

    # Restore DNS
    chattr -i /etc/resolv.conf 2>/dev/null
    if [ -f /etc/resolv.conf.backup ]; then
        cp /etc/resolv.conf.backup /etc/resolv.conf
        ok "DNS restored"
    fi

    # Stop Tor
    systemctl stop tor
    ok "Tor stopped"

    # Restore hostname
    hostnamectl set-hostname nikson
    sed -i "s/127.0.1.1.*/127.0.1.1    nikson/" /etc/hosts
    ok "Hostname restored: nikson"
    ok "Stealth mode disabled!"
}

